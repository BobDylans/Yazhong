# R2 Image Storage (Cloudflare)
# After setting up R2 public access, set this to your R2 public URL:
NEXT_PUBLIC_R2_URL=https://pub-xxxxx.r2.dev

# WhatsApp Number (international format, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=1234567890
